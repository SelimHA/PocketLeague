{
  "rules": {
    "lobbies": {
      "$code": {
        ".read": "auth != null",
        ".write": "auth != null",
        "teamCommands": {
          "$team": {
            ".read": "auth != null && root.child('lobbies/'+$code+'/players/'+auth.uid).exists()",
            "$cmd": {
              ".write": "auth != null && root.child('lobbies/'+$code+'/players/'+auth.uid).exists() && root.child('lobbies/'+$code+'/players/'+auth.uid+'/team').val() === $team && newData.child('issuedBy').val() === auth.uid && newData.child('team').val() === $team",
              ".validate": "$team.matches(/^(blue|orange)$/) && newData.hasChildren(['intent','target','team','issuedBy','issuedByName','source','confidence','strength','createdAt','expiresAt']) && newData.child('intent').isString() && newData.child('intent').val().matches(/^(ATTACK_BALL|TAKE_SHOT|DEFEND_GOAL|ROTATE_BACK|CLEAR_BALL|PASS_LEFT|PASS_RIGHT|GET_BOOST|GOALKEEPER_HOLD|TEAM_PRESS|MARK_OPPONENT|SPREAD_OUT|CENTER_BALL|HOLD_POSITION|SUPPORT_ME)$/) && newData.child('target').isString() && newData.child('target').val().length <= 24 && newData.child('issuedByName').isString() && newData.child('issuedByName').val().length <= 18 && newData.child('source').isString() && newData.child('source').val().matches(/^(quick|voice|text|server)$/) && newData.child('confidence').isNumber() && newData.child('confidence').val() >= 0 && newData.child('confidence').val() <= 1 && newData.child('strength').isNumber() && newData.child('strength').val() >= 0.1 && newData.child('strength').val() <= 1 && newData.child('createdAt').isNumber() && newData.child('expiresAt').isNumber() && newData.child('expiresAt').val() <= newData.child('createdAt').val() + 12000"
            }
          }
        },
        "commandSettings": {
          ".read": "auth != null && root.child('lobbies/'+$code+'/players/'+auth.uid).exists()",
          ".write": "auth != null && root.child('lobbies/'+$code+'/players/'+auth.uid+'/isHost').val() === true",
          "enabled": {
            ".validate": "newData.isBoolean()"
          },
          "serverAiEnabled": {
            ".validate": "newData.isBoolean()"
          },
          "voiceEnabled": {
            ".validate": "newData.isBoolean()"
          },
          "sameTeamOnly": {
            ".validate": "newData.isBoolean()"
          },
          "$other": {
            ".validate": true
          }
        }
      }
    },
    "profiles": {
      "$uid": {
        ".read": "auth != null",
        ".write": "auth != null && auth.uid === $uid",
        "username": {
          ".validate": "newData.isString() && newData.val().matches(/^[a-z0-9_-]{3,18}$/)"
        },
        "displayName": {
          ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 18"
        },
        "$other": {
          ".validate": true
        }
      }
    },
    "usernames": {
      "$name": {
        ".read": "auth != null",
        ".write": "auth != null && (!data.exists() || data.val() === auth.uid || newData.val() === auth.uid)",
        ".validate": "$name.matches(/^[a-z0-9_-]{3,18}$/) && newData.isString() && newData.val() === auth.uid"
      }
    },
    "leaderboard": {
      ".read": "auth != null",
      ".indexOn": [
        "points",
        "wins",
        "games"
      ],
      "$uid": {
        ".write": "auth != null && auth.uid === $uid",
        "uid": {
          ".validate": "newData.val() === auth.uid"
        },
        "username": {
          ".validate": "newData.isString() && newData.val().matches(/^[a-z0-9_-]{3,18}$/)"
        },
        "displayName": {
          ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 18"
        },
        "points": {
          ".validate": "newData.isNumber() && newData.val() >= 0"
        },
        "wins": {
          ".validate": "newData.isNumber() && newData.val() >= 0"
        },
        "draws": {
          ".validate": "newData.isNumber() && newData.val() >= 0"
        },
        "losses": {
          ".validate": "newData.isNumber() && newData.val() >= 0"
        },
        "games": {
          ".validate": "newData.isNumber() && newData.val() >= 0"
        },
        "goalsFor": {
          ".validate": "newData.isNumber() && newData.val() >= 0"
        },
        "goalsAgainst": {
          ".validate": "newData.isNumber() && newData.val() >= 0"
        },
        "$other": {
          ".validate": true
        }
      }
    },
    "voice": {
      "$code": {
        ".read": "auth != null",
        ".write": "auth != null",
        "presence": {
          "$uid": {
            ".write": "auth != null && auth.uid === $uid"
          }
        },
        "signals": {
          "$targetUid": {
            ".read": "auth != null && auth.uid === $targetUid",
            "$signalId": {
              ".write": "auth != null && (auth.uid === newData.child('from').val() || auth.uid === $targetUid)"
            }
          }
        }
      }
    },
    "settings": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid",
        "$other": {
          ".validate": true
        }
      }
    }
  }
}